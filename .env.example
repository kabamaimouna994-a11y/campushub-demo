# ─── Base de données ──────────────────────────────────────────────────────────
# Dev (SQLite) - commenté pour utiliser PostgreSQL
# DATABASE_URL=sqlite+aiosqlite:///./campushub.db

# Prod (PostgreSQL) — décommenté
DATABASE_URL=postgresql+asyncpg://campushub:campushub_secret@localhost:5432/campushub
POSTGRES_DB=campushub
POSTGRES_USER=campushub
POSTGRES_PASSWORD=campushub_secret

# ─── Sécurité ─────────────────────────────────────────────────────────────────
SECRET_KEY=dev-secret-key-change-in-production-use-openssl-rand-hex-32
DEBUG=true

# ─── Email (optionnel) ────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ─── Frontend ─────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000